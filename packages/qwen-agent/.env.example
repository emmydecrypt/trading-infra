# --- LLM (Qwen via DashScope, OpenAI-compatible) ---
# Get an API key from https://dashscope.aliyun.com/
QWEN_API_KEY=sk-your-dashscope-api-key
QWEN_BASE_URL=https://dashscope.aliyun.com/compatible-mode/v1
# Default for v1: qwen-plus (balanced); use qwen-turbo for cheapest, qwen-max for strongest.
QWEN_MODEL=qwen-plus

# --- MCP server (Bitget market data) ---
# Command + args used to spawn the MCP server over stdio.
# Defaults: spawn the local @bitget/mcp-server via tsx (dev) or node (built).
MCP_SERVER_CMD=node
MCP_SERVER_ARGS=/workspace/packages/mcp-server/dist/index.js
# If you prefer dev mode, set MCP_SERVER_CMD=tsx and MCP_SERVER_ARGS=/workspace/packages/mcp-server/src/index.ts

# --- Agent loop ---
# Seconds between decision ticks. 60s default.
AGENT_TICK_SECONDS=60
# Symbol to trade. Default BTCUSDT.
AGENT_SYMBOL=BTCUSDT
# Run duration passed via --duration, e.g. 10m, 2h, 30s. Default 10m.
AGENT_DURATION=10m
# Initial simulated cash (USDT). Default 10000.
AGENT_INITIAL_CASH=10000
# Log directory (relative to package root). Default logs/.
AGENT_LOG_DIR=logs
