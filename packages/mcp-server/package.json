{
  "name": "@bitget/mcp-server",
  "version": "0.1.0",
  "description": "MCP server exposing Bitget market data + trading signal tools for AI agents",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "bitget-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
