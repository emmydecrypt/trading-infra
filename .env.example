# =============================================================
# AI x Crypto Trading Infra — env vars
# =============================================================
# Copy this file to `.env` and fill in the values you have.
# NEVER commit `.env` — it is gitignored.

# -------------------------------------------------------------
# Qwen LLM (sponsor-supplied)
# Get yours after registering for the Bitget hackathon.
# Base URL works for DashScope's OpenAI-compatible mode.
# -------------------------------------------------------------
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# -------------------------------------------------------------
# Bitget (sponsor)
# Optional: the public market-data endpoints used by the MCP
# server do NOT need auth. Only fill these if you extend the
# server with private endpoints (account, orders).
# -------------------------------------------------------------
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_API_PASSPHRASE=

# -------------------------------------------------------------
# Solana on-chain reads
# Public mainnet RPC by default. For production use, point at
# Helius / Triton / QuickNode to avoid rate limits.
# -------------------------------------------------------------
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# -------------------------------------------------------------
# Eval harness
# -------------------------------------------------------------
EVAL_PORT=4000
EVAL_DB_PATH=./packages/eval-harness/data/eval.db

# -------------------------------------------------------------
# MCP server
# The server uses stdio transport — no HTTP port needed.
# Configurable via env if you run it as a service.
# -------------------------------------------------------------
MCP_LOG_LEVEL=info
